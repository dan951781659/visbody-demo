12"/></a:tc></a:tr><a:tr h="457200"><a:tc><a:txBody><a:bodyPr/><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"/><a:t>水下称重法</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p></a:txBody><a:tcPr marL="91425" marR="91425" marT="45712" marB="45712"/></a:tc><a:tc><a:txBody><a:bodyPr/><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"/><a:t>FM 和 FFM 密度不同，测量过程以水作为介质，测得人体体积，通过人体在水中和空气中的质量，求得身体密度，并由身体密度推算出 FM 和 FFM。</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p></a:txBody><a:tcPr marL="91425" marR="91425" marT="45712" marB="45712"/></a:tc><a:tc><a:txBody><a:bodyPr/><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"/><a:t>黄金标准</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p></a:txBody><a:tcPr marL="91425" marR="91425" marT="45712" marB="45712"/></a:tc><a:tc><a:txBody><a:bodyPr/><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"/><a:t>准，</a:t></a:r><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"><a:solidFill><a:srgbClr val="FF0000"/></a:solidFill><a:sym typeface="+mn-ea"/></a:rPr><a:t>黄金标准</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p><a:p><a:pPr><a:buNone/></a:pPr><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p></a:txBody><a:tcPr marL="91425" marR="91425" marT="45712" marB="45712"/></a:tc><a:tc><a:txBody><a:bodyPr/><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"/><a:t>难、繁琐、仅科研</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p></a:txBody><a:tcPr marL="91425" marR="91425" marT="45712" marB="45712"/></a:tc></a:tr><a:tr h="457200"><a:tc><a:txBody><a:bodyPr/><a:p><a:pPr><a:buNone/></a:pPr><a:r><a:rPr lang="zh-CN" altLang="en-US" sz="1200"/><a:t>体格测量法</a:t></a:r><a:endParaRPr lang="zh-CN" altLang="en-US" sz="1200"/></a:p></a:txBody><a:tcPr marL="91425" marR="91425" marT="45712" marB="45712"/></a:t